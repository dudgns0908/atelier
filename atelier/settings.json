{
  "permissions": {
    "allow": [
      "Bash(git status)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git branch:*)",
      "Bash(git checkout:*)",
      "Bash(git pull)",
      "Bash(git fetch:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git push -u origin feature/*)",
      "Bash(git merge:*)",
      "Bash(gh pr create:*)",
      "Bash(gh pr view:*)",
      "Bash(gh pr list:*)",
      "Bash(gh pr merge:*)",
      "Bash(gh pr review:*)",
      "Bash(gh pr comment:*)",
      "Bash(glab mr create:*)",
      "Bash(glab mr view:*)",
      "Bash(glab mr list:*)",
      "Bash(glab mr merge:*)",
      "Bash(glab mr approve:*)",
      "Bash(glab api:*)",
      "Bash(atelier-open-pr:*)",
      "Bash(atelier-check-reviews:*)",
      "Bash(atelier-cleanup-feature:*)",
      "Bash(atelier-notify:*)"
    ],
    "deny": [
      "Bash(git push --force:*)",
      "Bash(git push --force-with-lease:*)",
      "Bash(git push -f:*)",
      "Bash(git push origin main:*)",
      "Bash(git push origin develop:*)",
      "Bash(git commit --no-verify:*)"
    ]
  }
}
